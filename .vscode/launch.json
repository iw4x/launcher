{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Launcher (GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/launcher/launcher/iw4x-launcher",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "XDG_CONFIG_HOME",
          "value": "${workspaceFolder}/.test-config"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "b",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}
